# ════════════════════════════════════════════
# .gitignore - SDET Elite Journey
# Node.js + TypeScript + Playwright
# Based on: github/gitignore/Node.gitignore
# ════════════════════════════════════════════

# ┌────────────────────────────────────────────────────────────┐
# │ DEPENDENCIES                                               │
# └────────────────────────────────────────────────────────────┘

node_modules/
jspm_packages/


# ┌────────────────────────────────────────────────────────────┐
# │ LOGS                                                       │
# └────────────────────────────────────────────────────────────┘

logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*


# ┌────────────────────────────────────────────────────────────┐
# │ TESTING & REPORTS (Playwright + Coverage)                 │
# └────────────────────────────────────────────────────────────┘

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Coverage
coverage/
*.lcov
.nyc_output/

# Test reports (optional - uncomment if using)
# allure-results/
# allure-report/
# mochawesome-report/


# ┌────────────────────────────────────────────────────────────┐
# │ BUILD ARTIFACTS (TypeScript)                              │
# └────────────────────────────────────────────────────────────┘

dist/
build/
*.tsbuildinfo


# ┌────────────────────────────────────────────────────────────┐
# │ ENVIRONMENT & SECRETS                                      │
# └────────────────────────────────────────────────────────────┘

.env
.env.local
.env.development.local
.env.test.local
.env.production.local


# ┌────────────────────────────────────────────────────────────┐
# │ RUNTIME & CACHE                                            │
# └────────────────────────────────────────────────────────────┘

pids
*.pid
*.seed
*.pid.lock

.npm
.eslintcache
.node_repl_history


# ┌────────────────────────────────────────────────────────────┐
# │ IDE & EDITORS                                              │
# └────────────────────────────────────────────────────────────┘

.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

.idea/
*.swp
*.swo
*~


# ┌────────────────────────────────────────────────────────────┐
# │ OPERATING SYSTEM                                           │
# └────────────────────────────────────────────────────────────┘

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~


# ┌────────────────────────────────────────────────────────────┐
# │ DIAGNOSTIC & DEBUG                                         │
# └────────────────────────────────────────────────────────────┘

report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
